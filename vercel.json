{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CLOUDINARY_CLOUD_NAME": "ddzfagpvt",
    "CLOUDINARY_API_KEY": "J98WuHHV3rhFY5Se5UK4DqydcLE",
    "CLOUDINARY_API_SECRET": "your_api_secret"
  }
}

# MongoDB Configuration
MONGO_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/gluto-db?retryWrites=true&w=majority
# Alternative name that Vercel might use
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/gluto-db?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@glutointernational.com

# Environment
NODE_ENV=production